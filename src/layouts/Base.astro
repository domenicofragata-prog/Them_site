---
import '../styles/global.css';
import Grain from '../components/Grain.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  jsonld?: Record<string, unknown> | Record<string, unknown>[];
}

const { title = 'THEM', description = 'THEM — Domenico Fragata. Arte, suono, parola e codice come un\u2019unica ricerca.', jsonld } = Astro.props;
const lang = (Astro.currentLocale ?? 'it') as Lang;

const site = Astro.site ?? new URL('https://themproject.ai');
const path = Astro.url.pathname;
const canonical = new URL(path, site);
const origin = site.origin;

// Grafo di entità del sito (aiuta motori di ricerca e AI a capire chi/cosa è THEM)
const personDesc = lang === 'en'
  ? 'Domenico Fragata is an artist and philosopher working at the meeting point between sacred traditions and machine languages, under the project THEM.'
  : 'Domenico Fragata è un artista e filosofo che lavora sul punto di contatto tra le tradizioni sacre e i linguaggi delle macchine, con il progetto THEM.';

const siteGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebSite', '@id': `${origin}/#website`, url: `${origin}/`, name: 'THEM', inLanguage: lang, publisher: { '@id': `${origin}/#person` } },
    {
      '@type': 'Person', '@id': `${origin}/#person`, name: 'Domenico Fragata', alternateName: 'THEM',
      url: `${origin}/`, jobTitle: lang === 'en' ? 'Artist, philosopher' : 'Artista, filosofo',
      description: personDesc, image: `${origin}/og.jpg`,
      sameAs: ['https://www.instagram.com/them_artproject/', 'https://www.artuu.it/author/domenico-fragata/'],
    },
    { '@type': 'Organization', '@id': `${origin}/#org`, name: 'THEM', url: `${origin}/`, logo: `${origin}/og.jpg`, founder: { '@id': `${origin}/#person` } },
  ],
};
const extraJsonld = jsonld ? (Array.isArray(jsonld) ? jsonld : [jsonld]) : [];

// Percorsi equivalenti nelle due lingue (IT senza prefisso, EN sotto /en/)
const itPath = path.startsWith('/en') ? (path.replace(/^\/en/, '') || '/') : path;
const enPath = path.startsWith('/en') ? path : ('/en' + (path === '/' ? '' : path));
const itHref = new URL(itPath, site).href;
const enHref = new URL(enPath, site).href;

const ogImage = new URL('/og.jpg', site).href;
const ogLocale = lang === 'en' ? 'en_US' : 'it_IT';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="IJ4P1sjGB2uGQhB2UOgfydWFFFBPJBMoyIyLi4t5Zz4" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Domenico Fragata" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonical.href} />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="alternate" hreflang="it" href={itHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={itHref} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="THEM" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={title} />

    <script type="application/ld+json" set:html={JSON.stringify(siteGraph)} />
    {extraJsonld.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}
  </head>
  <body>
    <Grain />
    <Header />
    <main id="top">
      <slot />
    </main>
    <Footer />
    <script>
      // L'header resta visibile solo in cima (nella sua posizione); appena si scorre via, sparisce
      const header = document.querySelector('header.site');
      if (header) {
        const update = () => {
          if (window.scrollY > 80) header.classList.add('nav-hidden');
          else header.classList.remove('nav-hidden');
        };
        update();
        addEventListener('scroll', update, { passive: true });
      }
    </script>
    <script>
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (es) => {
            es.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.18 }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in'));
      }
    </script>
  </body>
</html>
