---
import Base from '../../layouts/Base.astro';
import FacePage from '../../components/FacePage.astro';
import WorksGrid from '../../components/WorksGrid.astro';
import { t, type Lang } from '../../i18n/ui';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const tr = t(lang);
---
<Base title="THEM · Art">
  <FacePage title={tr('nav.arte')} lead={tr('page.arte.lead')} leadClass="lead-wide">
    <WorksGrid />
  </FacePage>
</Base>
