---
import Base from '../../../layouts/Base.astro';
import FacePage from '../../../components/FacePage.astro';
import CodeTexture from '../../../components/CodeTexture.astro';
import { getCollection, render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t, type Lang } from '../../../i18n/ui';

export async function getStaticPaths() {
  const posts = await getCollection('writing', (p) => p.data.lang === 'en' && !p.data.external);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const lang = (Astro.currentLocale ?? 'en') as Lang;
const tr = t(lang);
const url = (p: string) => getRelativeLocaleUrl(lang, p);
const fmt = new Intl.DateTimeFormat('en-GB', { day: '2-digit', month: 'long', year: 'numeric' });

const site = Astro.site!;
const abs = new URL(Astro.url.pathname, site).href;
const articleLd = {
  '@context': 'https://schema.org',
  '@type': post.data.external ? 'Article' : 'BlogPosting',
  headline: post.data.title,
  description: post.data.excerpt,
  datePublished: post.data.date.toISOString(),
  inLanguage: lang,
  url: abs,
  author: { '@type': 'Person', '@id': `${site.origin}/#person`, name: 'Domenico Fragata' },
  publisher: { '@id': `${site.origin}/#org` },
};
---
<Base title={`THEM · ${post.data.title}`} description={post.data.excerpt} jsonld={articleLd}>
  <CodeTexture word="THEM" />
  <FacePage title={post.data.title}>
    <section class="prose prose-wide">
      <div class="wrap">
        <p class="mono">{fmt.format(post.data.date)} · {tr('writing.kicker')}</p>
        <Content />
        <a href={url('blog')} class="back-link">&#8592; {tr('back')}</a>
      </div>
    </section>
  </FacePage>
</Base>
