---
import Base from '../../layouts/Base.astro';
import FacePage from '../../components/FacePage.astro';
import CodeTexture from '../../components/CodeTexture.astro';
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t, type Lang } from '../../i18n/ui';

const lang = (Astro.currentLocale ?? 'it') as Lang;
const tr = t(lang);
const url = (p: string) => getRelativeLocaleUrl(lang, p);

const posts = (await getCollection('writing', (p) => p.data.lang === lang)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = new Intl.DateTimeFormat(lang === 'en' ? 'en-GB' : 'it-IT', { day: '2-digit', month: 'short', year: 'numeric' });

const order = ['riflessioni', 'articoli', 'rassegna', 'pubblicazioni'] as const;
const sections = order
  .map((cat) => ({ cat, items: posts.filter((p) => p.data.category === cat) }))
  .filter((s) => s.items.length > 0);
---
<Base title="THEM · blog">
  <CodeTexture word="THEM" />
  <FacePage title={tr('blog.title')} titleLines={[tr('writing.kicker'), 'blog']} animate={true} lead={tr('blog.lead')} leadClass="lead-wide">
    <section class="prose" style="max-width:none">
      <div class="wrap">
        {sections.length === 0 && <p class="mono">{tr('blog.empty')}</p>}

        {sections.map((s) => (
          <div class="blog-cat">
            <div class="cat-head">
              <h2>{tr(`blog.cat.${s.cat}` as any)}</h2>
            </div>
            {s.cat === 'pubblicazioni' && <p class="cat-note">{tr('blog.note.pubblicazioni')}</p>}
            <div class="post-list">
              {s.items.map((p, idx) => {
                const external = p.data.external;
                const href = external ?? url('blog/' + p.id);
                return (
                  <a
                    href={href}
                    class:list={['post-item', { extra: idx >= 3 }]}
                    {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  >
                    <span class="pdate">{fmt.format(p.data.date)}</span>
                    <span>
                      <span class="ptitle">
                        {p.data.title}
                        {external && <span class="pext">{p.data.publication ?? 'Link'} &#8599;</span>}
                      </span>
                      <span class="pexcerpt" style="display:block">{p.data.excerpt}</span>
                    </span>
                  </a>
                );
              })}
            </div>
            {s.items.length > 3 && (
              <button class="cat-toggle mono" data-toggle aria-expanded="false" data-more={`${tr('blog.showall')} (${s.items.length})`} data-less={tr('blog.showless')}>
                {tr('blog.showall')} ({s.items.length})
              </button>
            )}
          </div>
        ))}
      </div>
    </section>
  </FacePage>
  <script>
    document.querySelectorAll<HTMLButtonElement>('[data-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const cat = btn.closest('.blog-cat');
        if (!cat) return;
        const open = cat.classList.toggle('open');
        btn.setAttribute('aria-expanded', String(open));
        btn.textContent = open ? (btn.dataset.less || '') : (btn.dataset.more || '');
      });
    });
  </script>
</Base>
