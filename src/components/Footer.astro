---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { t, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'it') as Lang;
const tr = t(lang);
// Il blog esiste solo in italiano: qualsiasi lingua rimanda a /blog/
const url = (p: string) => getRelativeLocaleUrl(p === 'blog' ? 'it' : lang, p);
const year = new Date().getFullYear();

const items = [
  { slug: 'bio', label: tr('nav.bio') },
  { slug: 'formazione', label: tr('nav.formazione') },
  { slug: 'blog', label: tr('nav.divulgazione') },
  { slug: 'arte', label: tr('nav.arte') },
  { slug: 'musica', label: tr('nav.musica') },
  { slug: 'vibe-coding', label: tr('nav.vibe') },
];
---
<footer class="site">
  <div class="wrap">
    <div class="foot-top">
      <div class="foot-mark" aria-label="THEM"><span class="ascii-text" aria-hidden="true">THEM</span></div>
      <nav class="foot-links">
        {items.map((it) => (
          <a href={url(it.slug)} aria-label={it.label}><span class="ascii-text" aria-hidden="true">{it.label}</span></a>
        ))}
      </nav>
    </div>
    <p class="foot-note">{tr('foot.note')}</p>
    <div class="foot-contact">
      <span class="fc-label mono">{tr('foot.contact')}</span>
      <nav class="fc-links" aria-label={tr('foot.contact')}>
        <a class="fc-ico" href="mailto:domenico.fragata@gmail.com" aria-label="Email: domenico.fragata@gmail.com">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m3.5 7.5 8.5 5.5 8.5-5.5"/></svg>
          <span class="fc-tip mono">domenico.fragata@gmail.com</span>
        </a>
        <a class="fc-ico" href="https://www.instagram.com/them_artproject/" target="_blank" rel="noopener noreferrer" aria-label="Instagram: @them_artproject">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5.5"/><circle cx="12" cy="12" r="4"/><circle cx="17.4" cy="6.6" r="1.1" fill="currentColor" stroke="none"/></svg>
          <span class="fc-tip mono">@them_artproject</span>
        </a>
        <a class="fc-ico" href="https://wa.me/393386427639" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp: +39 338 642 7639">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.04 2.5c-5.23 0-9.48 4.25-9.48 9.48 0 1.67.44 3.3 1.27 4.74L2.5 21.5l4.9-1.28a9.44 9.44 0 0 0 4.64 1.2h.01c5.23 0 9.48-4.25 9.48-9.48 0-2.53-.99-4.91-2.78-6.7a9.42 9.42 0 0 0-6.71-2.74Zm0 1.7a7.76 7.76 0 0 1 7.78 7.78c0 4.29-3.49 7.78-7.79 7.78a7.8 7.8 0 0 1-3.96-1.08l-.28-.17-2.9.76.78-2.83-.19-.29a7.72 7.72 0 0 1-1.19-4.17c0-4.29 3.49-7.78 7.78-7.78Zm-4.35 4.2c-.2 0-.53.08-.8.38-.28.3-1.06 1.04-1.06 2.53s1.08 2.93 1.24 3.14c.15.2 2.11 3.35 5.19 4.6.72.28 1.29.45 1.73.58.73.23 1.39.2 1.91.12.58-.09 1.79-.73 2.04-1.44.25-.71.25-1.31.18-1.44-.07-.12-.28-.2-.58-.35-.3-.15-1.79-.88-2.06-.98-.28-.1-.48-.15-.68.15-.2.3-.78.98-.96 1.18-.18.2-.35.23-.65.08-.3-.15-1.27-.47-2.42-1.49-.9-.8-1.5-1.78-1.67-2.08-.18-.3-.02-.46.13-.61.14-.14.3-.35.45-.53.15-.18.2-.3.3-.5.1-.2.05-.38-.02-.53-.08-.15-.68-1.65-.93-2.26-.24-.58-.49-.5-.68-.51h-.58Z"/></svg>
          <span class="fc-tip mono">+39 338 642 7639</span>
        </a>
      </nav>
    </div>
    <div class="foot-bottom">
      <span class="mono">&copy; {year} THEM · Domenico Fragata</span>
      <span class="mono">{tr('foot.built')}</span>
    </div>
  </div>
</footer>
