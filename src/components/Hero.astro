---
import { Image } from 'astro:assets';
import artemide from '../assets/artemide.jpg';
import { t, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? 'it') as Lang;
const tr = t(lang);
---
<section class="hero">
  <Image src={artemide} alt="Artemide — Gods of the Digital Age" class="hero-art" widths={[768, 1280, 1920, 2560]} sizes="100vw" loading="eager" />
  <div class="hero-scrim"></div>
  <div class="hero-copy">
    <h1 class="slogan" aria-label="Hack the system"><span class="ascii-text" aria-hidden="true">HACK</span><br /><span class="ascii-text" aria-hidden="true">THE</span><br /><span class="ascii-text" aria-hidden="true">SYSTEM</span><span class="cursor" aria-hidden="true">_</span></h1>
    <p class="sub sub-mono">glitching the machine</p>
    <span class="scrollcue mono"><span class="line"></span><span>{tr('hero.scroll')}</span></span>
  </div>
</section>
